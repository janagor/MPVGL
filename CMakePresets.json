{
  "version": 6,
  "configurePresets": [
    {
      "name": "dev",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "dev",
      "configurePreset": "dev",
      "jobs": 12
    },
    {
      "name": "format",
      "configurePreset": "dev",
      "targets": ["format"]
    }
  ],
  "workflowPresets": [
    {
      "name": "dev",
      "steps": [
        { "type": "configure", "name": "dev"    },
        { "type": "build",     "name": "format" },
        { "type": "build",     "name": "dev"    }
      ]
    }
  ]
}

