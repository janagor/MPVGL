CompileFlags:
  CompilationDatabase: "${CMAKE_CURRENT_BINARY_DIR}"
  Add:
    - -std=gnu++26
    - -DGLFW_INCLUDE_NONE
    - -DGLFW_INCLUDE_VULKAN

    - -I${CMAKE_CURRENT_SOURCE_DIR}/include

    - -I${CMAKE_CURRENT_SOURCE_DIR}/lib
    - -I${CMAKE_CURRENT_SOURCE_DIR}/lib/glm
    - -I${CMAKE_CURRENT_SOURCE_DIR}/lib/glslang
    - -I${CMAKE_CURRENT_SOURCE_DIR}/lib/glfw/include
    - -I${CMAKE_CURRENT_SOURCE_DIR}/lib/tinyobjloader
    - -I${CMAKE_CURRENT_SOURCE_DIR}/lib/vk-bootstrap/src
    - -Wno-unknown-warning-option
  Remove: [-m*, -f*]
